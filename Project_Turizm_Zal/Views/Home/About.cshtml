@{
    ViewData["Title"] = "О музее";
}

<style>
    .about-hero {
        background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.6)), url('/images/about/hero.jpg');
        background-size: cover;
        background-position: center 30%;
        padding: 80px 0;
        text-align: center;
        color: white;
        margin-bottom: 50px;
    }

    .about-hero h1 {
        font-size: 3rem;
        font-weight: 600;
        margin-bottom: 20px;
    }

    .about-hero p {
        font-size: 1.2rem;
        opacity: 0.9;
        max-width: 700px;
        margin: 0 auto;
    }

    .facts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 25px;
        margin-bottom: 60px;
    }

    .fact-card {
        background: #f4f4f4; 
        border-radius: 20px;
        padding: 25px 15px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .fact-number {
        font-size: 2.8rem;
        font-weight: 700;
        color: #d4af37;
        margin-bottom: 8px;
    }

    .fact-label {
        font-size: 0.9rem;
        color: #555;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .history-block {
        display: flex;
        flex-wrap: wrap;
        gap: 40px;
        margin-bottom: 60px;
        align-items: flex-start;
    }

    .history-text {
        flex: 1.2;
        border-right: 2px solid #e0e0e0;
        padding-right: 30px;
    }

    .history-text h3 {
        font-size: 1.8rem;
        margin-bottom: 20px;
        color: #1f1f1f;
    }

    .history-text p {
        line-height: 1.6;
        color: #444;
        margin-bottom: 15px;
    }

    .history-image {
        flex: 1;
    }

    .history-image img {
        width: 100%;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }
    .history-image .photo-caption {
        text-align: center;
        margin-top: 12px;
        font-size: 0.85rem;
        color: #777;
    }

    .branches-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
        gap: 20px;
        margin: 30px 0 50px;
    }

    .branch-card {
        background: #f9f9f9;
        border-radius: 16px;
        padding: 18px;
        transition: all 0.2s;
        border-left: 4px solid #d4af37;
        display: flex;
        align-items: center;
        gap: 15px;
        text-decoration: none; 
        color: inherit;
    }

    .branch-card:hover {
        background: white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        transform: translateY(-2px);
    }

    .branch-icon {
        width: 48px;
        height: 48px;
        object-fit: contain;
        flex-shrink: 0;
    }

    .branch-info {
        flex: 1;
    }

    .branch-name {
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 5px;
        color: #1f1f1f;
    }

    .branch-location {
        font-size: 0.85rem;
        color: #777;
    }

   
    .gallery-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 20px;
        margin: 30px 0 50px;
    }

    .gallery-main img {
        width: 100%;
        height: 400px; 
        object-fit: cover;
        border-radius: 20px;
    }

    .gallery-thumbs {
        display: grid;
        grid-template-columns: repeat(2, 1fr); 
        gap: 15px;
        height: 400px; 
    }

    .gallery-thumbs img {
        width: 100%;
        height: calc((400px - 15px) / 2); 
        object-fit: cover;
        border-radius: 16px;
        cursor: pointer;
        transition: 0.2s;
    }

    .gallery-thumbs img:hover {
        transform: scale(1.02);
        opacity: 0.85;
    }


    .section-divider {
        height: 3px;
        background-color: #bababa; 
        margin: 50px 0;
        width: 100%;
    }

    .section-title {
        text-align: left;
        font-weight: 800;
        font-size: 1.8rem;
        margin-bottom: 25px;
        letter-spacing: -0.3px;
        color: #1f1f1f;
        border-left: 4px solid #bababa;
        padding-left: 20px;
    }

</style>



<div class="about-hero">
    <div class="content-container">
        <h1>Национальный музей<br>Республики Северная Осетия–Алания</h1>
        <p>Один из старейших музеев России — хранитель истории, культуры и традиций осетинского народа с 1893 года</p>
    </div>
</div>

<div class="content-container">
    <div class="facts-grid">
        <div class="fact-card"><div class="fact-number">1893</div><div class="fact-label">год основания</div></div>
        <div class="fact-card"><div class="fact-number">221 363</div><div class="fact-label">единиц хранения</div></div>
        <div class="fact-card"><div class="fact-number">13</div><div class="fact-label">филиалов</div></div>
        <div class="fact-card"><div class="fact-number">7 325</div><div class="fact-label">м² общей площади</div></div>
    </div>

    <div class="section-divider"></div>
    <div class="history-block">
        <div class="history-text">
            <h3 class="section-title">Более 130 лет истории</h3>
            <p><strong>1893 год</strong> — основание «Терского областного музея» по инициативе культурной общественности Владикавказа. Музей отмечен в энциклопедии Брокгауза и Эфрона как один из 36 областных музеев России.</p>
            <p><strong>1902 год</strong> — начало строительства здания в Соборном переулке (ныне ул. Ботоева, 3) по проекту архитектора И.В. Рябикина. Торжественная передача здания музею состоялась 21 января 1927 года.</p>
            <p><strong>1918–1936 годы</strong> — музей переходит в ведение Комиссариата народного образования, затем становится Северо-Кавказским институтом краеведения, а позже — Северо-Осетинским областным краеведческим музеем.</p>
            <p><strong>С 1967 года</strong> — музей размещается в историческом особняке на <strong>проспекте Мира, 11</strong> (памятник культурного наследия, ранее принадлежавший предпринимателю Я. Ходякову).</p>
            <p><strong>2018–2020 годы</strong> — масштабная реконструкция и реставрация зданий на проспекте Мира, 7–11 (особняк Ходякова и корпус бывшей табачной фабрики Б. Вахтангова).</p>
            <p><strong>9 сентября 2020 года</strong> — открытие обновлённой экспозиции, построенной на тематико-хронологическом принципе: от древнейших времён до XXI века, прослеживающей этногенез осетинского народа и этапы социально-экономического развития Осетии.</p>
            
        </div>
        <div class="history-image">
            <img src="/images/about/national_museum/national_museum.png" alt="Здание музея" onerror="this.src='https://via.placeholder.com/500x350?text=Историческое здание'">
            <div class="photo-caption">Главное здание на проспекте Мира, 11</div>
        </div>
    </div>

    <div class="section-divider"></div>

    <h3 class="section-title">Наша музейная сеть — 11 филиалов</h3>
    <div class="branches-grid">
        <a href="https://vmuzey.com/museum/memorialnyy-dom-muzey-k-l-hetagurova" class="branch-card">
            <img src="/images/about/branches/house_khetagurov.png" class="branch-icon" onerror="this.src='https://via.placeholder.com/48?text=Дом-музей Коста Хетагурова'">
            <div class="branch-info">
                <div class="branch-name">Дом-музей Коста Хетагурова</div>
                <div class="branch-location">Владикавказ / с. Нар</div>
            </div>
        </a>
        <a href="https://idemvmuzei.ru/catalog/museum/memorialnyj-dom-muzej-i-a-plieva" class="branch-card">
            <img src="/images/about/branches/Pliev.png" class="branch-icon" onerror="this.src='https://via.placeholder.com/48?text=Дом-музей генерала И.А. Плиева'">
            <div class="branch-info">
                <div class="branch-name">Дом-музей генерала И.А. Плиева</div>
                <div class="branch-location">Владикавказ</div>
            </div>
        </a>
        <a href="https://iryston.tv/teleproject_release/dom-muzej-hadzhi-umara-mamsurova-chto-dalshe/" class="branch-card">
            <img src="/images/about/branches/Mamsurov.png" class="branch-icon" onerror="this.src='https://via.placeholder.com/48?text=Музей генерала Х.-У.Дж. Мамсурова'">
            <div class="branch-info">
                <div class="branch-name">Музей генерала Х.-У.Дж. Мамсурова</div>
                <div class="branch-location">с. Ольгинское (на реконструкции)</div>
            </div>
        </a>
        <a href="https://idemvmuzei.ru/en/catalog/museum/istoriko-memorialnyj-dom-muzej-g-cagolova" class="branch-card">
            <img src="/images/about/branches/Tsagolov.png" class="branch-icon" onerror="this.src='https://via.placeholder.com/48?text=Музей Г.А. Цаголова'">
            <div class="branch-info">
                <div class="branch-name">Музей Г.А. Цаголова</div>
                <div class="branch-location">Дигора</div>
            </div>
        </a>
        <a href="https://idemvmuzei.ru/catalog/museum/majramadagskij-muzej-zasitnikov-suarskogo-usela" class="branch-card">
            <img src="/images/about/branches/syarski_yshelie.png" class="branch-icon" onerror="this.src='https://via.placeholder.com/48?text=Музей защитников Суарского ущелья'">
            <div class="branch-info">
                <div class="branch-name">Музей защитников Суарского ущелья</div>
                <div class="branch-location">с. Майрамадаг</div>
            </div>
        </a>
        <a href="https://vmuzey.com/museum/muzey-istorii-goroda-vloadikavkaz" class="branch-card">
            <img src="/images/about/branches/historyOsetia.png" class="branch-icon" onerror="this.src='https://via.placeholder.com/48?text=Музей истории Владикавказа'">
            <div class="branch-info">
                <div class="branch-name">Музей истории Владикавказа</div>
                <div class="branch-location">Владикавказ</div>
            </div>
        </a>
        <a href="https://www.culture.ru/institutes/69903/muzei-osetinskoi-literatury-im-k-l-khetagurova" class="branch-card">
            <img src="/images/about/branches/osetia_literature.png" class="branch-icon" onerror="this.src='https://via.placeholder.com/48?text=Музей осетинского языка и литературы'">
            <div class="branch-info">
                <div class="branch-name">Музей осетинского языка и литературы</div>
                <div class="branch-location">Владикавказ</div>
            </div>
        </a>
        <a href="https://www.culture.ru/institutes/20797/muzei-istorii-kultury-i-narodnogo-obrazovaniya-g-ardon" class="branch-card">
            <img src="/images/about/branches/ardon.png" class="branch-icon" onerror="this.src='https://via.placeholder.com/48?text=Музей народного образования'">
            <div class="branch-info">
                <div class="branch-name">Музей народного образования</div>
                <div class="branch-location">Ардон</div>
            </div>
        </a>
        <a href="https://www.culture.ru/institutes/22110/mozdokskii-muzei-kraevedeniya" class="branch-card">
            <img src="/images/about/branches/mozdok.png" class="branch-icon" onerror="this.src='https://via.placeholder.com/48?text=Музей краеведения'">
            <div class="branch-info">
                <div class="branch-name">Музей краеведения</div>
                <div class="branch-location">Моздок</div>
            </div>
        </a>
        <a href="https://vmuzey.com/museum/otdel-prirody-nacionalnogo-muzeya-rso-alaniya" class="branch-card">
            <img src="/images/about/branches/otdel_priroda.png" class="branch-icon" onerror="this.src='https://via.placeholder.com/48?text=Отдел природы'">
            <div class="branch-info">
                <div class="branch-name">Отдел природы</div>
                <div class="branch-location">Владикавказ</div>
            </div>
        </a>
        <a href="https://bolshayastrana.com/dostoprimechatelnosti/severnaya-osetiya/gorod-mertvyh-dargavs-114" class="branch-card">
            <img src="/images/about/branches/dargavs.png" class="branch-icon" onerror="this.src='https://via.placeholder.com/48?text=Даргавский некрополь «Город мёртвых'">
            <div class="branch-info">
                <div class="branch-name">Даргавский некрополь «Город мёртвых»</div>
                <div class="branch-location">с. Даргавс</div>
            </div>
        </a>
    </div>

    <div class="section-divider"></div>

    
    <h3 class="section-title">Фотогалерея</h3>
    <div class="gallery-grid">
        <div class="gallery-main">
            <img id="mainGalleryImg" src="/images/about/fhotoGallery/main.png" alt="Основное фото"
                 onerror="this.src='https://via.placeholder.com/800x600?text=Основное+фото'">
        </div>
        <div class="gallery-thumbs">
            <img src="/images/about/fhotoGallery/thumb1.png" alt="Миниатюра 1" data-img="/images/about/fhotoGallery/gallery1.png"
                 onerror="this.src='https://via.placeholder.com/200x150?text=Фото1'">
            <img src="/images/about/fhotoGallery/thumb2.png" alt="Миниатюра 2" data-img="/images/about/fhotoGallery/gallery2.png"
                 onerror="this.src='https://via.placeholder.com/200x150?text=Фото2'">
            <img src="/images/about/fhotoGallery/thumb3.png" alt="Миниатюра 3" data-img="/images/about/fhotoGallery/gallery3.png"
                 onerror="this.src='https://via.placeholder.com/200x150?text=Фото3'">
            <img src="/images/about/fhotoGallery/thumb4.png" alt="Миниатюра 4" data-img="/images/about/fhotoGallery/gallery4.png"
                 onerror="this.src='https://via.placeholder.com/200x150?text=Фото4'">
          
        </div>
    </div>

    <script>

        document.addEventListener('DOMContentLoaded', function() {
            const mainImg = document.getElementById('mainGalleryImg');
            const thumbs = document.querySelectorAll('.gallery-thumbs img');
            thumbs.forEach(thumb => {
                thumb.addEventListener('click', function() {
                    const newSrc = this.getAttribute('data-img') || this.src;
                    if (newSrc) mainImg.src = newSrc;
                });
            });
        });
    </script>
</div>