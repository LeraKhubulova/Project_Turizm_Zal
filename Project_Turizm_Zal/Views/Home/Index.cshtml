@{
    ViewData["Title"] = "Главная";
}

@model IEnumerable<MuseumHall>

<div class="content-container">
    <div class="full-width-carousel carousel-gradient-overlay">
        <div id="mainCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="2"></button>
            </div>
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="/images/index/slider/zal_1.png" class="d-block w-100" alt="Музей">
                    <div class="carousel-caption d-none d-md-block">
                        <h3>Добро пожаловать</h3>
                        <p>Погрузитесь в мир искусства и истории</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="/images/index/slider/zal_2.png" class="d-block w-100" alt="Экспонаты">
                    <div class="carousel-caption d-none d-md-block">
                        <h3>Уникальные экспонаты</h3>
                        <p>Тысячи артефактов со всего мира</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="/images/index/slider/zal_3.png" class="d-block w-100" alt="Экскурсии">
                    <div class="carousel-caption d-none d-md-block">
                        <h3>Невероятная история</h3>
                        <p>Посетите музей не выходя из дома</p>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#mainCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#mainCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>
    </div>

    
    <div class="welcome-section text-center mb-5">
        <h1 class="display-4">Виртуальный музей</h1>
        <p class="lead">Исследуйте богатую историю и культуру в нашем цифровом пространстве</p>
    </div>


    <h2 class="text-center mb-4">Наши залы</h2>
    <div class="row g-4 mb-5">
        @foreach (var hall in Model)
        {
            <div class="col-md-4">
                <div class="hall-card">
                    <img src="@hall.ImagePath" class="hall-img" alt="@hall.Name">
                    <div class="hall-card-body">
                        <h3>@hall.Name</h3>
                        <p>@hall.Description</p>
                        <a asp-controller="Halls" asp-action="Details" asp-route-id="@hall.Id" class="btn-custom">Узнать подробнее</a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="stats-section row text-center mb-5 py-4 mx-0">
        <div class="col-md-3">
            <div class="stat-number">50+</div>
            <div class="stat-label">Экспонатов</div>
        </div>
        <div class="col-md-3">
            <div class="stat-number">3</div>
            <div class="stat-label">Тематических зала</div>
        </div>
        <div class="col-md-3">
            <div class="stat-number">100+</div>
            <div class="stat-label">Довольных посетителей</div>
        </div>
        <div class="col-md-3">
            <div class="stat-number">24/7</div>
            <div class="stat-label">Доступ онлайн</div>
        </div>
    </div>

    <div class="map-section mb-5">
        <h2 class="text-center mb-4">Как нас найти</h2>
        <div class="map-container rounded-3 overflow-hidden">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2916.6687890094204!2d44.680620499999996!3d43.027358199999995!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x405aa0789fa91d9f%3A0x8953cb97917235ff!2z0J3QsNGG0LjQvtC90LDQu9GM0L3Ri9C5INC80YPQt9C10Lk!5e0!3m2!1sru!2sru!4v1778704706128!5m2!1sru!2sru"
             width="100%" height="350" style="border:0;" allowfullscreen="" loading="lazy">
            </iframe>
            <div class="map-address text-center mt-3">
                <p>📍 г. Владикавказ, ул. проспект Мира, 11</p>
                <p>📞 7 960 405-60-05 | museum@mail.ru</p>
            </div>
        </div>
    </div>
</div>