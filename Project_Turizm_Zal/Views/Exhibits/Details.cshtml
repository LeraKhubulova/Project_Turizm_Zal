@model Project_Turizm_Zal.Models.Exhibit

@{
    ViewData["Title"] = Model.Name;
}

<div class="content-container">
    <div class="hall-detail" style="background: white; border-radius: 2px; padding: 2rem; margin: 2rem 0; box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);">

       
        <h1 style="font-size: 2.5rem; font-weight: 600; color: #1f1f1f; border-left: 4px solid #d4af37; padding-left: 20px; margin-bottom: 1.5rem;">
            @Model.Name
        </h1>

     
        <div style="display: flex; align-items: stretch; gap: 2rem; flex-wrap: wrap;">
            
            <div style="flex: 1; min-width: 280px; display: flex; align-items: center; justify-content: center;">
                <img src="@Model.Images?.FirstOrDefault()" alt="@Model.Name"
                     style="width: 100%; height: 400px; object-fit: cover; border-radius: 2px; box-shadow: 0 5px 15px rgba(0,0,0,0.1);" />
            </div>

        
            <div style="flex: 1; min-width: 280px; display: flex; flex-direction: column; justify-content: center;">
                <h3 style="font-size: 1.3rem; font-weight: 600; padding-left: 20px; margin-bottom: 1rem; border-left: none;">Характеристики</h3>
                <table style="width: 100%; border-collapse: collapse; border: none;">
                    <tbody>
                        <tr>
                            <td style="padding: 6px 12px; font-weight: 600; width: 35%; color: #1f1f1f;"><i class="fas fa-clock"></i> Культура / эпоха</td>
                            <td style="padding: 6px 12px; color: #444;">@Model.CultureEra</td>
                        </tr>
                        <tr>
                            <td style="padding: 6px 12px; font-weight: 600;"><i class="fas fa-map-marker-alt"></i> Место находки</td>
                            <td style="padding: 6px 12px; color: #444;">@Model.FindLocation</td>
                        </tr>
                        <tr>
                            <td style="padding: 6px 12px; font-weight: 600;"><i class="fas fa-cube"></i> Материалы</td>
                            <td style="padding: 6px 12px; color: #444;">@Model.Materials</td>
                        </tr>
                        <tr>
                            <td style="padding: 6px 12px; font-weight: 600;"><i class="fas fa-tools"></i> Техника</td>
                            <td style="padding: 6px 12px; color: #444;">@Model.Technique</td>
                        </tr>
                        <tr>
                            <td style="padding: 6px 12px; font-weight: 600;"><i class="fas fa-ruler-combined"></i> Размеры</td>
                            <td style="padding: 6px 12px; color: #444;">@Model.Dimensions</td>
                        </tr>
                        <tr>
                            <td style="padding: 6px 12px; font-weight: 600;"><i class="fas fa-weight"></i> Вес</td>
                            <td style="padding: 6px 12px; color: #444;">@Model.Weight</td>
                        </tr>
                        <tr>
                            <td style="padding: 6px 12px; font-weight: 600;"><i class="fas fa-sort-amount-up"></i> Количество фигурок</td>
                            <td style="padding: 6px 12px; color: #444;">@Model.Quantity</td>
                        </tr>
                        <tr>
                            <td style="padding: 6px 12px; font-weight: 600;"><i class="fas fa-archive"></i> Место хранения</td>
                            <td style="padding: 6px 12px; color: #444;">@Model.Storage</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        
        
        <div style="margin-top: 2rem;">
            <h3 style="font-size: 1.3rem; font-weight: 600; border-left: 4px solid #d4af37; padding-left: 20px;">Описание</h3>
            <p style="line-height: 1.6; color: #444; padding-left: 24px;">@Model.Description</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.Model3DUrl))
        {
            <div style="margin-top: 2rem;">
                <h3 style="font-size: 1.3rem; font-weight: 600; border-left: 4px solid #d4af37; padding-left: 20px;">3D-модель</h3>
                <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; margin-top: 1rem;">
                    <iframe src="@Model.Model3DUrl"
                            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; border-radius: 2px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);"
                            allowfullscreen
                            allow="autoplay; fullscreen; vr"
                            loading="lazy">
                    </iframe>
                </div>
                <p style="color: #999; font-size: 0.85rem; margin-top: 0.5rem; padding-left: 24px;">
                    <i class="fas fa-rotate"></i> Вращайте мышью, чтобы осмотреть модель
                </p>
            </div>
        }


        <div style="margin-top: 2rem;">
            <a asp-controller="Halls" asp-action="Details" asp-route-id="@Model.MuseumHallId" class="btn-custom">Назад в зал</a>
        </div>
    </div>
</div>