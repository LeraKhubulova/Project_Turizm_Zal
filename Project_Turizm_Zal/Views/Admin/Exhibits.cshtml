@model List<Project_Turizm_Zal.Models.MuseumHall>

@{
    ViewData["Title"] = "Управление экспонатами";
}

<div class="container py-5">
    <h1 class="mb-4">Управление экспонатами</h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="mb-4">
        <a asp-controller="Admin"
           asp-action="Index"
           class="btn btn-secondary">
            Назад в админку
        </a>

        <a asp-controller="Admin"
           asp-action="AddExhibit"
           class="btn"
           style="background-color: #8b7355; border-color: #8b7355; color: white;">
            Добавить экспонат
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            Залы пока не созданы.
        </div>
    }
    else
    {
        @foreach (var hall in Model)
        {
            <div class="card shadow mb-4">
                <div class="card-header">
                    <h4 class="mb-0">
                        @hall.Number. @hall.Name
                    </h4>
                </div>

                <div class="card-body">
                    @if (hall.Exhibits == null || !hall.Exhibits.Any())
                    {
                        <p class="text-muted mb-0">
                            В этом зале пока нет экспонатов.
                        </p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>Фото</th>
                                        <th>Название</th>
                                        <th>Краткое описание</th>
                                        <th style="width: 180px;">Действия</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @foreach (var exhibit in hall.Exhibits)
                                    {
                                        <tr>
                                            <td>
                                                @if (exhibit.Images != null && exhibit.Images.Any())
                                                {
                                                    <img src="@exhibit.Images.First()"
                                                         alt="@exhibit.Name"
                                                         style="width: 90px; height: 70px; object-fit: cover; border-radius: 6px;" />
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Нет фото</span>
                                                }
                                            </td>

                                            <td>
                                                @exhibit.Name
                                            </td>

                                            <td>
                                                @exhibit.ShortDescription
                                            </td>

                                            <td>
                                                <a asp-controller="Exhibits"
                                                   asp-action="Details"
                                                   asp-route-id="@exhibit.Id"
                                                   class="btn btn-sm btn-outline-secondary">
                                                    Открыть
                                                </a>

                                                <a asp-controller="Admin"
                                                   asp-action="EditExhibit"
                                                   asp-route-id="@exhibit.Id"
                                                   class="btn btn-sm btn-warning">
                                                    Редактировать
                                                </a>

                                                <form asp-controller="Admin"
                                                      asp-action="DeleteExhibit"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden"
                                                           name="id"
                                                           value="@exhibit.Id" />

                                                    <button type="submit"
                                                            class="btn btn-sm btn-danger"
                                                            onclick="return confirm('Удалить экспонат «@exhibit.Name»?');">
                                                        Удалить
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>