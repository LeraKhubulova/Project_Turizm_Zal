@model MuseumHall

@{
    ViewData["Title"] = Model.Name;
}

<h2>@Model.Name</h2>
<p>Номер зала: @Model.Number</p>
<p>@Model.Description</p>

@if (!string.IsNullOrEmpty(Model.ImagePath))
{
    <img src="@Model.ImagePath" alt="@Model.Name" style="max-width:100%;" />
}
else
{
    <p>фотка не загружена</p>
}