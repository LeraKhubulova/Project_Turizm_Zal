            { name: "Мемфис (Мит-Рахина)", coords: [29.844, 31.254], artifacts: "Колосс Рамсеса II" },
        ];

        sites.forEach(site => {
            let marker = L.marker(site.coords).addTo(map);
            marker.bindPopup(`<b>${site.name}</b><br>${site.artifacts}`);
