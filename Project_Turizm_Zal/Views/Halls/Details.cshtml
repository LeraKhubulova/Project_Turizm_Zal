@model Project_Turizm_Zal.Models.MuseumHall

@{
    ViewData["Title"] = Model.Name;
}

<style>
    body {
        background-color: #f5f5f5;
        color: #1f1f1f;
    }

    .content-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 5%;
    }

    .hall-detail {
        background: white;
        border-radius: 2px;
        padding: 32px;
        margin: 32px 0;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
    }

    .hall-title {
        font-size: 12px;
        color: #555;
        
        padding-left: 16px;
        margin-bottom: 32px;
        font-weight: bold;
    }

    .hall-slogan {
        ont-size: 40px;
        font-weight: 600;
        color: #1f1f1f;
        margin-bottom: 8px;
        letter-spacing: -0.5px;
        border-left:4px solid #d4af37;
        padding-left: 20px;
    }

    .description-wrapper h3 {
        font-size: 24px;
        font-weight: 600;
        margin: 0 0 16px 0;
        color: #1f1f1f;
        border-left: 4px solid #d4af37;
        padding-left: 20px;
    }

    .description-text p {
        line-height: 1.6;
        color: #444;
        margin-bottom: 16px;
        padding-left: 24px;
    }

    .hall-img {
        width: 100%;
        height: auto;
        border-radius: 2px;
        margin-bottom: 24px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }

    .two-columns {
        display: flex;
        flex-wrap: wrap;
        gap: 32px;
        margin: 32px 0;
    }

    .col-description {
        flex: 1.2;
    }

    .col-map {
        flex: 1;
        min-height: 400px;
    }

    .map-container-leaflet {
        background: #f0f0f0;
        border-radius: 2px;
        overflow: hidden;
        width: 100%;
        height: 100%;
        min-height: 500px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    #hallMap {
        width: 100%;
        height: 100%;
        background: #e8e8e8;
    }

    .exhibits-title {
        font-size: 26px;
        font-weight: 600;
        margin: 32px 0 24px;
        color: #1f1f1f;
        border-left: 4px solid #d4af37;
        padding-left: 20px;
    }

    .exhibit-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 24px;
        margin-top: 16px;
    }

    .exhibit-card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        transition: box-shadow 0.3s ease;
        cursor: pointer;
        height: 100%;
    }

    .exhibit-card:hover {
        box-shadow: 0 10px 15px rgba(0, 0, 0, 0.17);
    }

    .exhibit-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }

    .exhibit-body {
        padding: 20px;
    }

    .exhibit-name {
        font-size: 21px;
        font-weight: 600;
        margin-bottom: 10px;
        color: #1f1f1f;
    }

    .exhibit-desc {
        color: #666;
        margin-bottom: 15px;
        line-height: 1.4;
    }
</style>

<div class="content-container">
    <div class="hall-detail">

        <h1 class="hall-slogan">@Model.Slogan</h1>

        <div class="hall-title">@Model.Name</div>

        <img src="@Model.ImagePath" alt="@Model.Name" class="hall-img" />

        <div class="two-columns">
            <div class="col-description">

                <div class="description-wrapper">
                    <h3>Описание зала</h3>
                    <div class="description-text">
                        <p>@Model.Description</p>
                        @if (!string.IsNullOrEmpty(Model.LeftColumnText))
                        {
                            <p>@Html.Raw(Model.LeftColumnText)</p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-map">
                @if (!string.IsNullOrEmpty(Model.MapData))
                {
                    <div class="map-container-leaflet" style="width: 100%; height: 100%;">
                        <div id="hallMap" style="width: 100%; height: 400px;"></div>
                    </div>
                    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
                    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
                    <script>
                        var mapData = @Html.Raw(Model.MapData);
                        var map = L.map('hallMap').setView([mapData.centerLat, mapData.centerLng], mapData.zoom);
                        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>'
                        }).addTo(map);
                        mapData.markers.forEach(m => {
                            L.marker([m.lat, m.lng]).addTo(map).bindPopup(m.popup);
                        });
                    </script>
                }
                else
                {
                    <div class="map-container-leaflet" style="display: flex; align-items: center; justify-content: center;">
                        <p style="color: #999;">Интерактивная карта отсутствует</p>
                    </div>
                }
            </div>
        </div>

        <h3 class="exhibits-title">Экспонаты</h3>
        <div class="exhibit-grid">
            @foreach (var exhibit in Model.Exhibits)
            {
                <div class="exhibit-card" onclick="location.href='/Exhibits/Details/@exhibit.Id'">
                    <img src="@exhibit.Images?.FirstOrDefault()" class="exhibit-img" />
                    <div class="exhibit-body">
                        <div class="exhibit-name">@exhibit.Name</div>
                        <div class="exhibit-desc">@exhibit.Description</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>